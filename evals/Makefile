# ModelSense eval harness. Requires uv. Golden answers are regenerated by the
# TypeScript server (single source of truth for model facts).

.PHONY: sync golden verify gate run score test lint fixtures

sync:
	uv sync --extra dev

# Regenerate golden/reference.json from the committed GLBs via the server logic.
golden:
	cd .. && pnpm --filter @modelsense/server golden

# Validate the golden set: schema + every ref resolves against reference.json.
verify:
	uv run evals verify-golden

# CI regression gate: replay recorded fixtures through the deterministic scorers.
gate:
	uv run evals gate

# LIVE run against the agent (spends tokens). Pass ARGS, e.g. ARGS="--category lookup --yes".
run:
	uv run evals run $(ARGS)

# Re-score recorded trajectories offline into a report. DIR defaults to fixtures.
score:
	uv run evals score $(or $(DIR),fixtures/trajectories)

# Regenerate the synthetic CI seed fixtures from reference.json.
fixtures:
	uv run python scripts/seed_fixtures.py

test:
	uv run pytest

lint:
	uv run ruff check src tests scripts
