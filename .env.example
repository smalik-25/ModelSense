# ModelSense environment. Copy this file to `.env` at the repo root and fill in
# real values. `.env` and `.env.*` are gitignored (except this example).
#
# Server-side secrets live in the root `.env` (loaded by apps/server and
# apps/agent) and, for deploys, in the Render dashboard as sync:false vars.
# NEVER put a secret behind a VITE_ prefix or in apps/web: Vite bakes VITE_*
# into the public client bundle.

# Anthropic: agent loop (Sonnet) + eval LLM-as-judge (Haiku). Server-side only.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# Langfuse Cloud (US region). Keys are region-scoped: US keys only authenticate
# against us.cloud.langfuse.com. The pk-/sk- prefix does not encode the region,
# so LANGFUSE_BASE_URL must match where the project was created.
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxx
LANGFUSE_BASE_URL=https://us.cloud.langfuse.com

# Shared bearer secret for the MCP server (agent -> server). Generate one with:
#   openssl rand -hex 32
MCP_API_KEY=generate-with-openssl-rand-hex-32

# Agent -> MCP server URL. Dev: the local server below. Combined prod deploy on
# Render: http://localhost:$PORT/mcp (same process hosts /mcp and /chat).
MCP_SERVER_URL=http://localhost:3000/mcp

# MCP server port for local dev. Render injects $PORT in production.
PORT=3000

# --- Agent service (apps/agent) --------------------------------------------
AGENT_PORT=8787
AGENT_MODEL=claude-sonnet-5
AGENT_MAX_TURNS=12
# Optional: restrict CORS to your web origin (defaults to *).
# WEB_ORIGIN=https://your-app.vercel.app
# Optional: enables the clickable Langfuse trace deep link in the UI.
# LANGFUSE_PROJECT_ID=your-langfuse-project-id
# Optional: only surface that deep link to visitors when the Langfuse project
# shares traces publicly (otherwise the link lands on a login wall). Default off.
# LANGFUSE_TRACES_PUBLIC=true

# ----------------------------------------------------------------------------
# Web (apps/web/.env.local). ONLY VITE_-prefixed, PUBLIC values here. This is
# the agent service URL the browser streams to. In production set it in the
# Vercel dashboard to the Render service URL (redeploy to bake it in).
# ----------------------------------------------------------------------------
# VITE_AGENT_URL=http://localhost:8787
